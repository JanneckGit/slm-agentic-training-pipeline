# =============================================================================
# .gitignore – Agentic SLM Training Pipeline
# =============================================================================

# NEVER commit secrets or local configs
config/pipeline_config.local.yaml
*.env
.env*

# Data (too large for git – use DVC or just document paths)
data/raw/
data/generated/
data/final/
data/evaluation/
data/input_marius
nohup.out


# Model checkpoints (very large)
checkpoints/
*.safetensors
*.bin
*.pt
*.pth

# HuggingFace cache
.cache/
hf_cache/

# Logs
logs/
sweep_logs/
*.log
runs/
mlruns/
# verl / Hydra / Ray run outputs (data/final/ diagnostics already covered above)
outputs/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
.venv-tau2/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# Archived artifacts (old teacher runs, deprecated experiment logs)
archive/

# Docker
docker/*.tar

# Editor
.vscode/
.idea/
*.swp
*.swo
