# =============================================================================
# .gitignore – Agentic SLM Training Pipeline
# =============================================================================

# NEVER commit secrets or local configs
config/pipeline_config.local.yaml
*.env
.env*

# Data (too large for git – use DVC or just document paths)
# Exception chain: the frozen GTFS snapshot (2.8 MB, CC-BY-4.0) IS committed — it anchors the
# byte-reproducible golden hashes and the original feed is no longer publicly available.
# gitignore quirk: exceptions under an ignored DIRECTORY never fire, hence un-ignore each level
# and re-ignore its contents with '*'.
!data/raw/
data/raw/*
!data/raw/db_sandbox/
data/raw/db_sandbox/*
!data/raw/db_sandbox/gtfs_de_fv/
data/generated/
data/final/
data/evaluation/
data/input_marius
nohup.out


# Model checkpoints (very large)
checkpoints/
*.safetensors
*.bin
*.pt
*.pth

# HuggingFace cache
.cache/
hf_cache/

# Logs
logs/
sweep_logs/
*.log
runs/
mlruns/
# verl / Hydra / Ray run outputs (data/final/ diagnostics already covered above)
outputs/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
.venv-tau2/
.venv-bfcl/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# Archived artifacts (old teacher runs, deprecated experiment logs)
archive/

# Design docs & decision log (local working notes, not repo content)
docs/

# Docker
docker/*.tar

# Editor
.vscode/
.idea/
*.swp
*.swo
