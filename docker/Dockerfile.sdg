# =============================================================================
# Dockerfile.sdg – data-acquisition container (CPU)
# =============================================================================
# Fetches the public SFT legs (ToolACE + AReaL) into data/raw/ via
# data_pipeline/prepare_agentic_data.py, and serves as the HF-download helper
# for ops/teacher_bakeoff.sh. The actual db_bahn SDG (rollout.py) runs on the
# HOST in the Py3.12 tau2 venv, NOT in this container.
# (2026-07-15 slimmed: sdg-hub/litellm/anthropic/openai + requirements_sdg.txt
#  removed — nothing in the container path imported them.)
# =============================================================================

FROM python:3.11-slim

LABEL maintainer="slm-agentic-training-pipeline"
LABEL description="Public-dataset acquisition (ToolACE/AReaL) for the agentic SFT mix"

# ---------------------------------------------------------------------------
# System dependencies
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Install uv (fast Python package manager)
# ---------------------------------------------------------------------------
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.cargo/bin:/root/.local/bin:$PATH"

# ---------------------------------------------------------------------------
# Python dependencies — exactly what prepare_agentic_data.py imports:
# huggingface_hub (snapshot fetch), datasets (ToolACE rows), pyyaml (config).
# ---------------------------------------------------------------------------
WORKDIR /app

RUN uv pip install --system \
    datasets \
    huggingface-hub \
    pyyaml

# ---------------------------------------------------------------------------
# Copy project code
# ---------------------------------------------------------------------------
COPY . .
RUN pip install -e . --no-deps   # editable 'slm-agentic-training-pipeline' pkg

# ---------------------------------------------------------------------------
# Data directories (will be mounted as volumes in docker-compose)
# ---------------------------------------------------------------------------
RUN mkdir -p /app/data/raw /app/data/generated /app/data/final /app/logs

# ---------------------------------------------------------------------------
# HuggingFace cache (mounted as volume for persistence)
# ---------------------------------------------------------------------------
ENV HF_HOME=/data/hf_cache
ENV TRANSFORMERS_CACHE=/data/hf_cache

# ---------------------------------------------------------------------------
# Entrypoint
# ---------------------------------------------------------------------------
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

CMD ["python", "data_pipeline/prepare_agentic_data.py", "--config", "config/pipeline_config.yaml"]
